{
    "name": "lingweave",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite --host 0.0.0.0 --port 3000",
        "sync:prompts": "node scripts/sync-prompts.mjs",
        "prepare:prompts": "node scripts/ensure-prompts.mjs",
        "predev": "node scripts/ensure-prompts.mjs",
        "build:docs": "cd ../docs && npm run build",
        "sync:docs": "node scripts/sync-docs.mjs",
        "map:docs": "npm run build:docs && npm run sync:docs",
        "prebuild": "node scripts/ensure-prompts.mjs && node scripts/sync-docs.mjs",
        "build": "vite build",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit",
        "start": "vite preview --host 0.0.0.0 --port 3000",
        "format": "prettier --write .",
        "format:check": "prettier --check ."
    },
    "dependencies": {
        "@codemirror/lang-json": "^6.0.2",
        "@tanstack/react-query": "^5.100.9",
        "@uiw/react-codemirror": "^4.25.9",
        "antd": "^6.4.2",
        "axios": "^1.16.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "copy-to-clipboard": "^4.0.2",
        "fflate": "^0.8.3",
        "file-saver": "^2.0.5",
        "localforage": "^1.10.0",
        "lucide-react": "^1.16.0",
        "motion": "^12.38.0",
        "nanoid": "^5.1.11",
        "radix-ui": "^1.4.3",
        "react": "19.2.5",
        "react-dom": "19.2.5",
        "react-router": "^7.12.0",
        "react-router-dom": "^7.12.0",
        "streamdown": "^2.5.0",
        "tailwind-merge": "^3.6.0",
        "tailwindcss": "^4",
        "tw-animate-css": "^1.4.0",
        "zustand": "^5.0.12"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4",
        "@types/file-saver": "^2.0.7",
        "@types/node": "^20",
        "@types/react": "19.1.12",
        "@types/react-dom": "19.1.9",
        "@vitejs/plugin-react": "^5.2.0",
        "happy-dom": "^20.10.6",
        "prettier": "^3.8.3",
        "shadcn": "^4.7.0",
        "sharp": "^0.34.5",
        "typescript": "^5",
        "vite": "^7.3.0",
        "vitest": "^4.1.10"
    },
    "overrides": {
        "@babel/core": "7.29.7",
        "form-data": "4.0.6",
        "hono": "4.12.30",
        "js-yaml": "4.3.0",
        "qs": "6.15.3"
    }
}
